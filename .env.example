# Serveur de prix Express (Railway ou local)
REACT_APP_API_URL=http://localhost:3001

# Supabase — récupérez ces valeurs dans : Settings > API de votre projet Supabase
REACT_APP_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Upstash Redis — cache Yahoo Finance entre les invocations Vercel
# Créez une base sur https://console.upstash.com et copiez REST URL + Token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase côté serveur (Vercel Functions) — différent des clés REACT_APP_
# SUPABASE_URL et SUPABASE_ANON_KEY peuvent reprendre les mêmes valeurs que REACT_APP_*
# SUPABASE_SERVICE_ROLE_KEY : Settings > API > service_role (garder secret, ne jamais exposer au frontend)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (VAPID) — générez vos clés avec :
# node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k,null,2));"
VAPID_PUBLIC_KEY=BObkAjCkSA67V_yV057yoccfXaljWR9319LtxzMx5FTHxWLPnypPK_QLgez7TXcplWDr1r8nsFPV4xnlFBgOQqM
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:contact@capitaly.fr

# Même clé publique exposée au frontend React
REACT_APP_VAPID_PUBLIC_KEY=BObkAjCkSA67V_yV057yoccfXaljWR9319LtxzMx5FTHxWLPnypPK_QLgez7TXcplWDr1r8nsFPV4xnlFBgOQqM
